GROQ_API_KEY=your_groq_api_key_here

# Deepgram STT (Speech-to-Text for real-time transcription)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# For local development with ngrok
# Update this whenever you restart ngrok
NGROK_URL=your ngrok url here

# ============================================
# TWILIO + ELEVENLABS CONFIGURATION
# ============================================

# Twilio Credentials (from https://console.twilio.com/)
TWILIO_ACCOUNT_SID=twilio account sid here
TWILIO_AUTH_TOKEN=twilio auth token here
TWILIO_PHONE_NUMBER=twilio phone number here

# Your phone number (where calls will be received)
USER_PHONE_NUMBER=your phone number here

# ElevenLabs Configuration
# Agent ID and API Key for WebSocket streaming
ELEVENLABS_AGENT_ID=your agent id here
ELEVENLABS_API_KEY=your api key here

# Server configuration
NODE_ENV=development
PORT=3000

# Telnyx API
# TELNYX_API_KEY=telnyx api key here
# TELNYX_API_BASE_URL=telnyx api base url here

# # Telnyx Application (Voice API)
# TELNYX_APPLICATION_ID=your telnyx application id here

