{
  "compilerOptions": {
    "target": "ES2022",           // Updated from ES2017 (recommended)
    "lib": ["esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": false,
    "esModuleInterop": true,
    "module": "NodeNext",         // ← Best modern choice
    "moduleResolution": "NodeNext", // ← This fixes the deprecation
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "outDir": "./dist",
    "rootDir": "./"
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}